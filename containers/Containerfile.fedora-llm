FROM registry.fedoraproject.org/fedora:39

# Install essential packages for LLM training
RUN dnf update -y && \
    dnf install -y \
    python3 \
    python3-pip \
    python3-devel \
    gcc \
    gcc-c++ \
    git \
    wget \
    curl \
    vim \
    htop \
    nvidia-container-toolkit \
    && dnf clean all

# Install Python ML/AI packages
RUN pip3 install --no-cache-dir \
    torch \
    transformers \
    datasets \
    accelerate \
    bitsandbytes \
    peft \
    trl \
    wandb \
    tensorboard \
    jupyter \
    numpy \
    pandas \
    scikit-learn

# Create working directory
WORKDIR /opt/llm-training

# Copy training scripts
COPY training/ /opt/llm-training/

# Set environment variables
ENV PYTHONPATH=/opt/llm-training
ENV CUDA_VISIBLE_DEVICES=0

# Expose ports for Jupyter and TensorBoard
EXPOSE 8888 6006

# Default command
CMD ["python3", "train.py"]