FROM quay.io/fedora/fedora-bootc:42

# Install system packages, cloud-init, and dependencies in a single layer
RUN dnf install -y \
    python3 \
    python3-pip \
    python3-devel \
    gcc \
    gcc-c++ \
    git \
    wget \
    curl \
    vim \
    htop \
    podman \
    openssh-server \
    cloud-init \
    cloud-utils-growpart \
    nvidia-container-toolkit \
    && dnf clean all \
    && pip3 install --no-cache-dir \
        torch \
        transformers \
        datasets \
        accelerate \
        bitsandbytes \
        peft \
        trl \
        wandb \
        tensorboard \
        jupyter \
        numpy \
        pandas \
        scikit-learn \
        ramalama

# Create working directory
WORKDIR /opt/llm-training

# Copy unpackaged applications
COPY training/ /opt/llm-training/
COPY scripts/ /opt/scripts/

# Copy configuration files
COPY config/systemd/ /etc/systemd/system/
COPY config/ssh/ /etc/ssh/
COPY config/llm-training.conf /etc/llm-training/
COPY config/ramalama.conf /config/
COPY config/cloud-init/ /etc/cloud/

# Run configuration scripts
RUN chmod +x /opt/scripts/*.sh && \
    /opt/scripts/setup-llm-environment.sh && \
    systemctl enable llm-training.service && \
    systemctl enable ramalama-inference.service && \
    systemctl enable sshd && \
    systemctl enable cloud-init-local && \
    systemctl enable cloud-init && \
    systemctl enable cloud-config && \
    systemctl enable cloud-final

# Set environment variables for bootable container
ENV PYTHONPATH=/opt/llm-training
ENV CUDA_VISIBLE_DEVICES=0